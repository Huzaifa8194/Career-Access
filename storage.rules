rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    function isSignedIn() {
      return request.auth != null;
    }

    function isStaff() {
      return isSignedIn()
        && firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role in ['advisor', 'admin'];
    }

    function ownsParticipant(pid) {
      return isSignedIn()
        && firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.participantId == pid;
    }

    match /participants/{participantId}/{fileName=**} {
      allow read: if isStaff() || ownsParticipant(participantId);
      allow write: if (isSignedIn()
                      && (isStaff() || ownsParticipant(participantId))
                      && request.resource.size < 25 * 1024 * 1024);
      allow delete: if isStaff() || ownsParticipant(participantId);
    }

    match /applications/{applicationId}/{fileName=**} {
      allow read: if isStaff();
      allow write: if isSignedIn() && request.resource.size < 25 * 1024 * 1024;
      allow delete: if isStaff();
    }

    match /public/{fileName=**} {
      allow read: if true;
      allow write: if isStaff();
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
