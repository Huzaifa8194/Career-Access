rules_version = '2';

// Career Access Hub — Firebase Storage rules
// Mirrors the Data Connect @auth contract:
//   - anyone signed in may upload to their own intake folder
//   - advisors/admins may read any participant document
service firebase.storage {
  match /b/{bucket}/o {
    // Participant-scoped documents. Path shape:
    //   participants/{participantId}/{fileName}
    match /participants/{participantId}/{fileName=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.resource.size < 10 * 1024 * 1024  // 10 MB cap
        && request.resource.contentType.matches('application/pdf|image/.*');
    }

    // Public intake uploads (anonymous applicants). Path shape:
    //   intake/{sessionId}/{fileName}
    match /intake/{sessionId}/{fileName=**} {
      allow read: if request.auth != null;
      allow create: if request.resource.size < 10 * 1024 * 1024
        && request.resource.contentType.matches('application/pdf|image/.*');
      allow update, delete: if request.auth != null;
    }

    // Default deny
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
