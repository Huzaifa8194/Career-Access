rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function roleIs(role) {
      return signedIn() && userDoc().data.role == role;
    }

    function isStaff() {
      return roleIs("advisor") || roleIs("admin");
    }

    match /users/{uid} {
      allow read: if signedIn() && (request.auth.uid == uid || isStaff());
      allow create: if signedIn() && request.auth.uid == uid;
      allow update: if signedIn() && (request.auth.uid == uid || roleIs("admin"));
      allow delete: if false;
    }

    match /participants/{participantId} {
      allow create: if true;
      allow read: if isStaff() || (signedIn() && resource.data.userId == request.auth.uid);
      allow update: if isStaff() || (signedIn() && resource.data.userId == request.auth.uid);
      allow delete: if roleIs("admin");
    }

    match /applications/{applicationId} {
      allow create: if true;
      allow read: if isStaff() || (
        signedIn() &&
        get(/databases/$(database)/documents/participants/$(resource.data.participantId)).data.userId == request.auth.uid
      );
      allow update: if isStaff();
      allow delete: if roleIs("admin");
    }

    match /referrals/{referralId} {
      allow create: if true;
      allow read, update: if isStaff();
      allow delete: if roleIs("admin");
    }

    match /appointments/{appointmentId} {
      allow create: if true;
      allow read: if isStaff() || (
        signedIn() &&
        (
          resource.data.createdBy == request.auth.uid ||
          get(/databases/$(database)/documents/participants/$(resource.data.participantId)).data.userId == request.auth.uid
        )
      );
      allow update: if isStaff();
      allow delete: if roleIs("admin");
    }

    match /tasks/{taskId} {
      allow create, update: if isStaff();
      allow read: if isStaff() || (
        signedIn() &&
        get(/databases/$(database)/documents/participants/$(resource.data.participantId)).data.userId == request.auth.uid
      );
      allow delete: if roleIs("admin");
    }

    match /notes/{noteId} {
      allow create, read: if isStaff();
      allow update, delete: if roleIs("admin");
    }

    match /documents/{documentId} {
      allow create: if signedIn();
      allow read: if isStaff() || (
        signedIn() &&
        get(/databases/$(database)/documents/participants/$(resource.data.participantId)).data.userId == request.auth.uid
      );
      allow update: if isStaff();
      allow delete: if roleIs("admin");
    }

    match /messages/{messageId} {
      allow create: if signedIn();
      allow read: if isStaff() || (
        signedIn() &&
        get(/databases/$(database)/documents/participants/$(resource.data.participantId)).data.userId == request.auth.uid
      );
      allow update: if isStaff() || (signedIn() && resource.data.senderId == request.auth.uid);
      allow delete: if roleIs("admin");
    }

    match /dashboard_metrics/{metricId} {
      allow read: if isStaff();
      allow write: if roleIs("admin");
    }
  }
}
