rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function userRole() {
      return isSignedIn()
        ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role
        : null;
    }

    function isAdmin() {
      return userRole() == 'admin';
    }

    function isAdvisor() {
      return userRole() == 'advisor';
    }

    function isStaff() {
      return isAdmin() || isAdvisor();
    }

    function userParticipantId() {
      return isSignedIn()
        ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data.participantId
        : null;
    }

    match /users/{uid} {
      allow read: if isSignedIn() && (request.auth.uid == uid || isStaff());
      allow create: if isSignedIn() && request.auth.uid == uid
        && request.resource.data.role in ['participant', 'advisor', 'admin'];
      allow update: if isSignedIn() && (
        (request.auth.uid == uid
          && request.resource.data.role == resource.data.role)
        || isAdmin()
      );
      allow delete: if isAdmin();
    }

    match /participants/{pid} {
      allow read: if isStaff()
        || (isSignedIn() && (
              resource.data.userId == request.auth.uid
              || userParticipantId() == pid
           ));

      allow create: if isSignedIn()
        && (
          isStaff()
          || request.resource.data.userId == request.auth.uid
          || request.resource.data.userId == null
        );

      allow update: if isStaff()
        || (isSignedIn() && (
              resource.data.userId == request.auth.uid
              || userParticipantId() == pid
           ));

      allow delete: if isAdmin();
    }

    match /applications/{aid} {
      allow read: if isStaff()
        || (isSignedIn()
            && userParticipantId() == resource.data.participantId);
      allow create: if isSignedIn();
      allow update, delete: if isStaff();
    }

    match /referrals/{rid} {
      allow read: if isStaff();
      allow create: if true;
      allow update, delete: if isStaff();
    }

    match /advisors/{aid} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /appointments/{id} {
      allow read: if isStaff()
        || (isSignedIn()
            && userParticipantId() == resource.data.participantId);
      allow create: if true;
      allow update: if isStaff()
        || (isSignedIn()
            && userParticipantId() == resource.data.participantId);
      allow delete: if isAdmin();
    }

    match /tasks/{id} {
      allow read: if isStaff()
        || (isSignedIn()
            && userParticipantId() == resource.data.participantId);
      allow create, update, delete: if isStaff();
    }

    match /notes/{id} {
      allow read: if isStaff();
      allow create, update, delete: if isStaff();
    }

    match /documents/{id} {
      allow read: if isStaff()
        || (isSignedIn()
            && userParticipantId() == resource.data.participantId);
      allow create: if isSignedIn();
      allow update: if isStaff()
        || (isSignedIn()
            && userParticipantId() == resource.data.participantId);
      allow delete: if isStaff()
        || (isSignedIn()
            && userParticipantId() == resource.data.participantId);
    }

    match /messages/{id} {
      allow read: if isStaff()
        || (isSignedIn()
            && userParticipantId() == resource.data.participantId);
      allow create: if isSignedIn()
        && (
          isStaff()
          || userParticipantId() == request.resource.data.participantId
        );
      allow update: if isSignedIn()
        && (
          isStaff()
          || userParticipantId() == resource.data.participantId
        );
      allow delete: if isAdmin();
    }

    match /dashboard_metrics/{id} {
      allow read: if isStaff();
      allow write: if isAdmin();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
